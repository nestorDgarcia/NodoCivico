<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.nestorgarcia.nodocivico.ui.fragments.LoginFragment"
        android:label="Iniciar sesión"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.nestorgarcia.nodocivico.ui.fragments.HomeFragment"
        android:label="Inicio"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/reportListFragment"
        android:name="com.nestorgarcia.nodocivico.ui.fragments.ReportListFragment"
        android:label="Reportes"
        tools:layout="@layout/fragment_report_list">
        <action
            android:id="@+id/action_list_to_detail"
            app:destination="@id/reportDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/reportDetailFragment"
        android:name="com.nestorgarcia.nodocivico.ui.fragments.ReportDetailFragment"
        android:label="Detalle del reporte"
        tools:layout="@layout/fragment_report_detail">
        <argument
            android:name="reportId"
            app:argType="integer" />
        <action
            android:id="@+id/action_detail_to_edit"
            app:destination="@id/editReportFragment" />
    </fragment>

    <fragment
        android:id="@+id/createReportFragment"
        android:name="com.nestorgarcia.nodocivico.ui.fragments.CreateReportFragment"
        android:label="Nuevo reporte"
        tools:layout="@layout/fragment_create_report" />

    <fragment
        android:id="@+id/editReportFragment"
        android:name="com.nestorgarcia.nodocivico.ui.fragments.EditReportFragment"
        android:label="Editar reporte"
        tools:layout="@layout/fragment_edit_report">
        <argument
            android:name="reportId"
            app:argType="integer" />
    </fragment>

    <fragment
        android:id="@+id/remindersFragment"
        android:name="com.nestorgarcia.nodocivico.ui.fragments.RemindersFragment"
        android:label="Recordatorios"
        tools:layout="@layout/fragment_reminders" />

    <fragment
        android:id="@+id/syncStatusFragment"
        android:name="com.nestorgarcia.nodocivico.ui.fragments.SyncStatusFragment"
        android:label="Sincronización"
        tools:layout="@layout/fragment_sync_status" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.nestorgarcia.nodocivico.ui.fragments.ProfileFragment"
        android:label="Perfil"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.nestorgarcia.nodocivico.ui.fragments.SettingsFragment"
        android:label="Ajustes"
        tools:layout="@layout/fragment_settings" />

</navigation>